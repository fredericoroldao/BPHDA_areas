      const pred = workItems.find((item) => item.id === dep.predecessor_work_item_id)
      const succ = workItems.find((item) => item.id === dep.successor_work_item_id)
      const predProject = pred ? findProject(pred, new Map(workItems.map((item) => [item.id, item]))) : null
      const succProject = succ ? findProject(succ, new Map(workItems.map((item) => [item.id, item]))) : null

      const sourceOk = dependencySourceProjectId ? predProject?.id === dependencySourceProjectId : true
      const targetOk = dependencyTargetProjectId ? succProject?.id === dependencyTargetProjectId : true
      return sourceOk && targetOk
    })
  }, [dependencies, dependencySourceProjectId, dependencyTargetProjectId, workItems])

