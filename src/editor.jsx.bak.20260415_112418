      is_primary: true,
    })
    if (row?.id) setSelectedWorkItemAssignmentId(row.id)
  }

  async function createDependency() {
    const source = filteredDependencySourceItems.find((item) => item.type !== 'project')
    const target = filteredDependencyTargetItems.find((item) => item.type !== 'project' && item.id !== source?.id)
    if (!source || !target) {
      setError('Escolhe primeiro os projetos de origem e destino com tarefas disponíveis.')
      return
    }

    const row = await insertRow('work_item_dependencies', {
      predecessor_work_item_id: source.id,
      successor_work_item_id: target.id,
      dependency_type: 'finish_to_start',
      lag_days: 0,
      note: dependencyTypeOptions[0].help,
    })
    if (row?.id) setSelectedDependencyId(row.id)
  }

  async function moveArea(areaId, direction) {
    const sorted = areas.slice().sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))
    const pair = orderSwap(sorted, areaId, direction)
    if (!pair) return
    const [current, target] = pair
    await updateRow('areas', current.id, { sort_order: target.sort_order ?? 0 })
    await updateRow('areas', target.id, { sort_order: current.sort_order ?? 0 })
  }

  async function moveFunction(functionId, direction) {
    const selected = functions.find((fn) => fn.id === functionId)
    if (!selected) return
    const siblings = functions
      .filter((fn) => fn.area_id === selected.area_id && (fn.parent_function_id ?? '') === (selected.parent_function_id ?? ''))
      .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))
    const pair = orderSwap(siblings, functionId, direction)
    if (!pair) return
    const [current, target] = pair
    await updateRow('functions', current.id, { sort_order: target.sort_order ?? 0 })
    await updateRow('functions', target.id, { sort_order: current.sort_order ?? 0 })
  }

  async function moveWorkItem(itemId, direction) {
    const selected = workItems.find((item) => item.id === itemId)
    if (!selected) return
    const siblings = workItems
      .filter((item) => (item.parent_work_item_id ?? '') === (selected.parent_work_item_id ?? ''))
      .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))
    const pair = orderSwap(siblings, itemId, direction)
    if (!pair) return
    const [current, target] = pair
    await updateRow('work_items', current.id, { sort_order: target.sort_order ?? 0 })
    await updateRow('work_items', target.id, { sort_order: current.sort_order ?? 0 })
  }

