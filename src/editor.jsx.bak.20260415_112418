  const projectTasks = useMemo(() => {
    if (!selectedProjectId) return []
    const map = new Map(workItems.map((item) => [item.id, item]))
    const results = []

    function walk(parentId, depth) {
      const children = workItems
        .filter((item) => item.parent_work_item_id === parentId)
        .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))

      for (const child of children) {
        results.push({ ...child, depth })
        walk(child.id, depth + 1)
      }
    }

    walk(selectedProjectId, 0)
    return results
  }, [workItems, selectedProjectId])

