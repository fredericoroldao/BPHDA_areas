    if (row?.id) setSelectedPersonId(row.id)
  }

  async function createNewArea() {
    const nextOrder = (areas.at(-1)?.sort_order ?? -1) + 10
    const row = await insertRow('areas', { name: 'Nova área', sort_order: nextOrder, status: 'active' })
    if (row?.id) setSelectedAreaId(row.id)
  }

  async function createNewFunction(areaId) {
    const siblings = functions.filter((fn) => fn.area_id === areaId && !fn.parent_function_id)
    const nextOrder = (siblings.at(-1)?.sort_order ?? -1) + 10
    const row = await insertRow('functions', {
      area_id: areaId,
      name: 'Nova função',
      sort_order: nextOrder,
      status: 'active',
      level: 1,
    })
    if (row?.id) {
      setSelectedFunctionId(row.id)
      if (!openFunctionAreaIds.includes(areaId)) setOpenFunctionAreaIds((prev) => [...prev, areaId])
    }
  }

  async function createNewProject() {
    const nextOrder = (projects.at(-1)?.sort_order ?? -1) + 10
    const row = await insertRow('work_items', {
      type: 'project',
      name: 'Novo projeto',
      status: 'not_started',
      phase: 'planning',
      priority: 'medium',
      sort_order: nextOrder,
    })
    if (row?.id) {
      setSelectedProjectId(row.id)
      setSelectedWorkItemId(row.id)
    }
  }

  async function createTaskUnder(parent) {
    const siblings = workItems.filter((item) => item.parent_work_item_id === parent.id)
    const nextOrder = (siblings.at(-1)?.sort_order ?? -1) + 10
    const row = await insertRow('work_items', {
      parent_work_item_id: parent.id,
      type: parent.type === 'project' ? 'task' : 'subtask',
      name: parent.type === 'project' ? 'Nova tarefa' : 'Nova subtarefa',
      status: 'not_started',
      phase: 'planning',
      priority: 'medium',
      sort_order: nextOrder,
    })
    if (row?.id) setSelectedWorkItemId(row.id)
  }

