  async function updateRow(table, id, payload) {
    setSaving(true)
    clearMessages()
    const res = await supabase.from(table).update(payload).eq('id', id)
    setSaving(false)
    if (res.error) {
      setError(res.error.message)
      return false
    }
    setMessage('Guardado automaticamente.')
    await loadAll()
    return true
  }

  async function insertRow(table, payload) {
    setSaving(true)
    clearMessages()
    const res = await supabase.from(table).insert(payload).select().single()
    setSaving(false)
    if (res.error) {
      setError(res.error.message)
      return null
    }
    setMessage('Criado com sucesso.')
    await loadAll()
    return res.data
  }

  async function removeRow(table, id) {
    const ok = window.confirm('Tens a certeza que queres apagar este registo?')
    if (!ok) return

    setSaving(true)
    clearMessages()
    const res = await supabase.from(table).delete().eq('id', id)
    setSaving(false)

    if (res.error) {
      setError(res.error.message)
      return
    }

    setMessage('Apagado com sucesso.')
    await loadAll()
  }

