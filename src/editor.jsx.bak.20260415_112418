  const filteredDependencySourceItems = useMemo(() => {
    if (!dependencySourceProjectId) return []
    const out = []
    function walk(parentId) {
      const children = workItems
        .filter((item) => item.id === parentId || item.parent_work_item_id === parentId)
        .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))

      for (const child of children) {
        if (!out.some((x) => x.id === child.id)) out.push(child)
        if (child.type !== 'project') walk(child.id)
      }
    }
    walk(dependencySourceProjectId)
    return out.filter((item) => item.id !== dependencySourceProjectId || item.type === 'project')
  }, [dependencySourceProjectId, workItems])

  const filteredDependencyTargetItems = useMemo(() => {
    if (!dependencyTargetProjectId) return []
    const out = []
    function walk(parentId) {
      const children = workItems
        .filter((item) => item.id === parentId || item.parent_work_item_id === parentId)
        .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt'))

      for (const child of children) {
        if (!out.some((x) => x.id === child.id)) out.push(child)
        if (child.type !== 'project') walk(child.id)
      }
    }
    walk(dependencyTargetProjectId)
    return out.filter((item) => item.id !== dependencyTargetProjectId || item.type === 'project')
  }, [dependencyTargetProjectId, workItems])

