                <div style={{ fontSize: 13, lineHeight: 1.45 }}>{dependencyType?.help}</div>
              </div>

              <label>Tooltip / explicação editável<textarea style={{ ...inputStyle, minHeight: 110 }} value={dependencyForm.note ?? ''} onChange={(e) => { setDependencyForm((s) => ({ ...s, note: e.target.value })); setDirty((d) => ({ ...d, dependency: true })) }} /></label>
              <label>Lag em dias<input type="number" style={inputStyle} value={dependencyForm.lag_days} onChange={(e) => { setDependencyForm((s) => ({ ...s, lag_days: e.target.value })); setDirty((d) => ({ ...d, dependency: true })) }} /></label>

              <div style={{ display: 'flex', gap: 8 }}>
                <button style={dangerButtonStyle} onClick={() => removeRow('work_item_dependencies', dependencyForm.id)}>Apagar</button>
              </div>
            </div>
          ) : (
            <div>Escolhe ou cria uma dependência.</div>
          )}
        </div>
      </div>
    )
  }

  function renderAssignmentsTab() {
    return (
      <div style={{ display: 'grid', gap: 16 }}>
        <div style={{ display: 'grid', gridTemplateColumns: '420px 1fr', gap: 16, alignItems: 'start' }}>
          <div style={boxStyle}>
            <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
              <strong>Atribuições de área</strong>
              <button onClick={createAreaAssignment} style={primaryButtonStyle}>+ Criar</button>
            </div>
            <div style={{ display: 'grid', gap: 6, maxHeight: 340, overflow: 'auto' }}>
              {areaPeople.map((row) => {
                const area = areas.find((a) => a.id === row.area_id)
                const person = people.find((p) => p.id === row.person_id)
                return (
                  <button key={row.id} style={selectedAreaAssignmentId === row.id ? primaryButtonStyle : { ...buttonStyle, textAlign: 'left' }} onClick={() => setSelectedAreaAssignmentId(row.id)}>
                    {area?.name ?? row.area_id} · {person?.name ?? row.person_id} · {row.assignment_role}
                  </button>
                )
              })}
            </div>
          </div>

          <div style={boxStyle}>
            {areaAssignmentForm ? (
              <div style={{ display: 'grid', gap: 10 }}>
                <label>Área<select style={inputStyle} value={areaAssignmentForm.area_id} onChange={(e) => { setAreaAssignmentForm((s) => ({ ...s, area_id: e.target.value })); setDirty((d) => ({ ...d, areaAssignment: true })) }}>{areas.map((area) => <option key={area.id} value={area.id}>{area.name}</option>)}</select></label>
                <label>Pessoa<select style={inputStyle} value={areaAssignmentForm.person_id} onChange={(e) => { setAreaAssignmentForm((s) => ({ ...s, person_id: e.target.value })); setDirty((d) => ({ ...d, areaAssignment: true })) }}>{people.map((person) => <option key={person.id} value={person.id}>{person.name}</option>)}</select></label>
                <label>Papel<select style={inputStyle} value={areaAssignmentForm.assignment_role} onChange={(e) => { setAreaAssignmentForm((s) => ({ ...s, assignment_role: e.target.value })); setDirty((d) => ({ ...d, areaAssignment: true })) }}>{areaRoleOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
                <label style={{ display: 'flex', gap: 8, alignItems: 'center' }}><input type="checkbox" checked={areaAssignmentForm.is_primary} onChange={(e) => { setAreaAssignmentForm((s) => ({ ...s, is_primary: e.target.checked })); setDirty((d) => ({ ...d, areaAssignment: true })) }} />Principal</label>
                <button style={dangerButtonStyle} onClick={() => removeRow('area_people', areaAssignmentForm.id)}>Apagar</button>
              </div>
            ) : <div>Escolhe uma atribuição de área.</div>}
          </div>
        </div>

        <div style={{ display: 'grid', gridTemplateColumns: '420px 1fr', gap: 16, alignItems: 'start' }}>
          <div style={boxStyle}>
            <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
              <strong>Atribuições de função</strong>
              <button onClick={createFunctionAssignment} style={primaryButtonStyle}>+ Criar</button>
            </div>
            <div style={{ display: 'grid', gap: 6, maxHeight: 340, overflow: 'auto' }}>
              {functionPeople.map((row) => {
                const fn = functions.find((f) => f.id === row.function_id)
                const person = people.find((p) => p.id === row.person_id)
                return (
                  <button key={row.id} style={selectedFunctionAssignmentId === row.id ? primaryButtonStyle : { ...buttonStyle, textAlign: 'left' }} onClick={() => setSelectedFunctionAssignmentId(row.id)}>
                    {fn ? functionLabel(fn) : row.function_id} · {person?.name ?? row.person_id} · {row.assignment_role}
                  </button>
                )
              })}
            </div>
          </div>

          <div style={boxStyle}>
            {functionAssignmentForm ? (
              <div style={{ display: 'grid', gap: 10 }}>
                <label>Função<select style={inputStyle} value={functionAssignmentForm.function_id} onChange={(e) => { setFunctionAssignmentForm((s) => ({ ...s, function_id: e.target.value })); setDirty((d) => ({ ...d, functionAssignment: true })) }}>{functions.map((fn) => <option key={fn.id} value={fn.id}>{functionLabel(fn)}</option>)}</select></label>
                <label>Pessoa<select style={inputStyle} value={functionAssignmentForm.person_id} onChange={(e) => { setFunctionAssignmentForm((s) => ({ ...s, person_id: e.target.value })); setDirty((d) => ({ ...d, functionAssignment: true })) }}>{people.map((person) => <option key={person.id} value={person.id}>{person.name}</option>)}</select></label>
                <label>Papel<select style={inputStyle} value={functionAssignmentForm.assignment_role} onChange={(e) => { setFunctionAssignmentForm((s) => ({ ...s, assignment_role: e.target.value })); setDirty((d) => ({ ...d, functionAssignment: true })) }}>{genericRoleOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
                <label style={{ display: 'flex', gap: 8, alignItems: 'center' }}><input type="checkbox" checked={functionAssignmentForm.is_primary} onChange={(e) => { setFunctionAssignmentForm((s) => ({ ...s, is_primary: e.target.checked })); setDirty((d) => ({ ...d, functionAssignment: true })) }} />Principal</label>
                <button style={dangerButtonStyle} onClick={() => removeRow('function_people', functionAssignmentForm.id)}>Apagar</button>
              </div>
            ) : <div>Escolhe uma atribuição de função.</div>}
          </div>
        </div>

        <div style={{ display: 'grid', gridTemplateColumns: '420px 1fr', gap: 16, alignItems: 'start' }}>
          <div style={boxStyle}>
            <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
              <strong>Atribuições de projeto / tarefa</strong>
              <button onClick={() => createWorkItemAssignment(selectedWorkItemId || workItems[0]?.id)} style={primaryButtonStyle}>+ Criar</button>
            </div>
            <div style={{ display: 'grid', gap: 6, maxHeight: 340, overflow: 'auto' }}>
              {workItemPeople.map((row) => {
                const item = workItems.find((w) => w.id === row.work_item_id)
                const person = people.find((p) => p.id === row.person_id)
                return (
                  <button key={row.id} style={selectedWorkItemAssignmentId === row.id ? primaryButtonStyle : { ...buttonStyle, textAlign: 'left' }} onClick={() => setSelectedWorkItemAssignmentId(row.id)}>
                    {item ? workItemLabel(item) : row.work_item_id} · {person?.name ?? row.person_id} · {row.assignment_role}
                  </button>
                )
              })}
            </div>
          </div>

          <div style={boxStyle}>
            {workItemAssignmentForm ? (
              <div style={{ display: 'grid', gap: 10 }}>
                <label>Projeto / tarefa<select style={inputStyle} value={workItemAssignmentForm.work_item_id} onChange={(e) => { setWorkItemAssignmentForm((s) => ({ ...s, work_item_id: e.target.value })); setDirty((d) => ({ ...d, workItemAssignment: true })) }}>{workItems.map((item) => <option key={item.id} value={item.id}>{workItemLabel(item)}</option>)}</select></label>
                <label>Pessoa<select style={inputStyle} value={workItemAssignmentForm.person_id} onChange={(e) => { setWorkItemAssignmentForm((s) => ({ ...s, person_id: e.target.value })); setDirty((d) => ({ ...d, workItemAssignment: true })) }}>{people.map((person) => <option key={person.id} value={person.id}>{person.name}</option>)}</select></label>
                <label>Papel<select style={inputStyle} value={workItemAssignmentForm.assignment_role} onChange={(e) => { setWorkItemAssignmentForm((s) => ({ ...s, assignment_role: e.target.value })); setDirty((d) => ({ ...d, workItemAssignment: true })) }}>{genericRoleOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
                <label style={{ display: 'flex', gap: 8, alignItems: 'center' }}><input type="checkbox" checked={workItemAssignmentForm.is_primary} onChange={(e) => { setWorkItemAssignmentForm((s) => ({ ...s, is_primary: e.target.checked })); setDirty((d) => ({ ...d, workItemAssignment: true })) }} />Principal</label>
                <button style={dangerButtonStyle} onClick={() => removeRow('work_item_people', workItemAssignmentForm.id)}>Apagar</button>
              </div>
            ) : <div>Escolhe uma atribuição de projeto / tarefa.</div>}
          </div>
        </div>
      </div>
    )
  }

  return (
    <>
      <style>{`
        :root {
          font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          color: #1d2a21;
          background: #f6f8f4;
        }

        html, body, #root {
          margin: 0;
          min-height: 100%;
          width: 100%;
        }

        body {
          background: #f6f8f4;
          color: #1d2a21;
        }

        * {
          box-sizing: border-box;
        }

        table {
          width: 100%;
          border-collapse: collapse;
        }

        label {
          display: grid;
          gap: 4px;
          font-size: 12px;
          color: #46604d;
        }

        select, input, textarea {
          font: inherit;
        }

        textarea {
          resize: vertical;
        }
      `}</style>

      <div style={{ maxWidth: 1680, margin: '0 auto', padding: '24px 18px 40px' }}>
        {renderHeader()}
        {renderTabs()}
        {renderStatusBoxes()}

        {loading ? <div style={boxStyle}>A carregar...</div> : null}

        {!loading && tab === 'people' ? renderPeopleTab() : null}
        {!loading && tab === 'areas' ? renderAreasTab() : null}
        {!loading && tab === 'functions' ? renderFunctionsTab() : null}
        {!loading && tab === 'projects' ? renderProjectsTab() : null}
        {!loading && tab === 'dependencies' ? renderDependenciesTab() : null}
        {!loading && tab === 'assignments' ? renderAssignmentsTab() : null}
      </div>
    </>
  )
}

createRoot(document.getElementById('root')).render(<EditorApp />)
