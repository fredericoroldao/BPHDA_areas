  async function loadAll() {
    setLoading(true)
    setError('')
    setMessage('')

    const [
      peopleRes,
      areasRes,
      functionsRes,
      workItemsRes,
      dependenciesRes,
      areaPeopleRes,
      functionPeopleRes,
      workItemPeopleRes,
    ] = await Promise.all([
      supabase.from('people').select('*').order('name', { ascending: true }),
      supabase.from('areas').select('*').order('sort_order', { ascending: true }).order('name', { ascending: true }),
      supabase.from('functions').select('*').order('sort_order', { ascending: true }).order('name', { ascending: true }),
      supabase.from('work_items').select('*').order('sort_order', { ascending: true }).order('name', { ascending: true }),
      supabase.from('work_item_dependencies').select('*'),
      supabase.from('area_people').select('*'),
      supabase.from('function_people').select('*'),
      supabase.from('work_item_people').select('*'),
    ])

    const all = [peopleRes, areasRes, functionsRes, workItemsRes, dependenciesRes, areaPeopleRes, functionPeopleRes, workItemPeopleRes]
    const firstError = all.find((r) => r.error)

    if (firstError?.error) {
      setError(firstError.error.message)
      setLoading(false)
      return
    }

    setPeople(peopleRes.data ?? [])
    setAreas(areasRes.data ?? [])
    setFunctions(functionsRes.data ?? [])
    setWorkItems(workItemsRes.data ?? [])
    setDependencies(dependenciesRes.data ?? [])
    setAreaPeople(areaPeopleRes.data ?? [])
    setFunctionPeople(functionPeopleRes.data ?? [])
    setWorkItemPeople(workItemPeopleRes.data ?? [])
    setLoading(false)
  }

  function clearMessages() {
    setError('')
    setMessage('')
  }

  function areaLabel(areaId) {
    return areas.find((a) => a.id === areaId)?.name ?? 'Sem área'
  }

  function functionLabel(fn) {
    return `${areaLabel(fn.area_id)}: ${fn.name}`
  }

  function workItemLabel(item) {
    const typeLabel = Object.fromEntries(workItemTypeOptions)[item.type] ?? item.type
    return `${typeLabel}: ${item.name}`
  }

  function personName(personId) {
    return people.find((p) => p.id === personId)?.name ?? ''
  }

  async function saveManual(table, form, payload, successMessage) {
    if (!form) return false

    setSaving(true)
    clearMessages()

    const res = form.id
      ? await supabase.from(table).update(payload).eq('id', form.id)
      : await supabase.from(table).insert(payload)

    setSaving(false)

    if (res.error) {
      setError(res.error.message)
      return false
    }

    setMessage(successMessage)
    await loadAll()
    return true
  }

  async function removeRow(table, id) {
    if (!id) return
    const ok = window.confirm('Tens a certeza que queres apagar este registo?')
    if (!ok) return

    setSaving(true)
    clearMessages()

    const res = await supabase.from(table).delete().eq('id', id)
    setSaving(false)

    if (res.error) {
      setError(res.error.message)
      return
    }

    setMessage('Registo apagado com sucesso.')
    await loadAll()
  }

  const sortedAreas = useMemo(
    () => [...areas].sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt')),
    [areas]
  )

  const sortedFunctions = useMemo(
    () => [...functions].sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt')),
    [functions]
  )

  const sortedWorkItems = useMemo(
    () => [...workItems].sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0) || a.name.localeCompare(b.name, 'pt')),
    [workItems]
  )

  const projects = useMemo(
    () => sortedWorkItems.filter((item) => item.type === 'project'),
    [sortedWorkItems]
  )

  const workItemMap = useMemo(
    () => new Map(workItems.map((item) => [item.id, item])),
    [workItems]
  )

  const functionsByArea = useMemo(() => {
    const grouped = {}
    for (const fn of sortedFunctions) {
      if (!grouped[fn.area_id]) grouped[fn.area_id] = []
      grouped[fn.area_id].push(fn)
    }
    return grouped
  }, [sortedFunctions])

  const functionsByParent = useMemo(() => {
    const grouped = {}
    for (const fn of sortedFunctions) {
      const key = fn.parent_function_id ?? '__root__'
      if (!grouped[key]) grouped[key] = []
      grouped[key].push(fn)
    }
    return grouped
  }, [sortedFunctions])

  const selectedAreaFunctions = useMemo(
    () => sortedFunctions.filter((fn) => fn.area_id === selectedAreaId),
    [sortedFunctions, selectedAreaId]
  )

  const selectedAreaAssignments = useMemo(
    () => areaPeople.filter((row) => row.area_id === selectedAreaId),
    [areaPeople, selectedAreaId]
  )

  const selectedFunctionAssignments = useMemo(
    () => functionPeople.filter((row) => row.function_id === selectedFunctionId),
    [functionPeople, selectedFunctionId]
  )

  const selectedProject = useMemo(
    () => projects.find((p) => p.id === selectedProjectId) ?? null,
    [projects, selectedProjectId]
  )

  const selectedProjectTasks = useMemo(() => {
    if (!selectedProjectId) return []

    const all = []
    const byParent = new Map()

    for (const item of sortedWorkItems) {
      const key = item.parent_work_item_id ?? '__root__'
      if (!byParent.has(key)) byParent.set(key, [])
      byParent.get(key).push(item)
    }

    function walk(parentId, depth = 0) {
      const children = byParent.get(parentId ?? '__root__') ?? []
      for (const child of children) {
        all.push({ ...child, depth })
        walk(child.id, depth + 1)
      }
    }

    walk(selectedProjectId, 0)
    return all
  }, [selectedProjectId, sortedWorkItems])

  const filteredDependencySourceItems = useMemo(() => {
    if (!dependencySourceProjectId) return []
    return sortedWorkItems.filter((item) => {
      const project = findProject(item, workItemMap)
      return project?.id === dependencySourceProjectId && item.type !== 'project'
    })
  }, [dependencySourceProjectId, sortedWorkItems, workItemMap])

  const filteredDependencyTargetItems = useMemo(() => {
    if (!dependencyTargetProjectId) return []
    return sortedWorkItems.filter((item) => {
      const project = findProject(item, workItemMap)
      return project?.id === dependencyTargetProjectId && item.type !== 'project'
    })
  }, [dependencyTargetProjectId, sortedWorkItems, workItemMap])

  const selectedWorkItemIncomingDependencies = useMemo(
    () => dependencies.filter((dep) => dep.successor_work_item_id === selectedWorkItemId),
    [dependencies, selectedWorkItemId]
  )

  const selectedWorkItemOutgoingDependencies = useMemo(
    () => dependencies.filter((dep) => dep.predecessor_work_item_id === selectedWorkItemId),
    [dependencies, selectedWorkItemId]
  )

  const selectedWorkItemProjectId = useMemo(() => {
    const item = workItemMap.get(selectedWorkItemId)
    if (!item) return ''
    return findProject(item, workItemMap)?.id ?? ''
  }, [selectedWorkItemId, workItemMap])

  function createDependencyIncomingForSelectedTask() {
    if (!selectedWorkItemId) return
    setSelectedDependencyId('')
