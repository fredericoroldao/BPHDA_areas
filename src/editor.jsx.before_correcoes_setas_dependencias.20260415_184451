  function renderFunctionTreeForArea(parentId = '', depth = 0) {
    const key = parentId || '__root__'
    const items = (functionsByParent[key] ?? []).filter((fn) => fn.area_id === selectedAreaId)
    if (!items.length) return null

    return (
      <div style={{ display: 'grid', gap: 6 }}>
        {items.map((fn) => (
          <div key={fn.id}>
            <div style={{ display: 'flex', gap: 6, marginLeft: depth * 16 }}>
              <button
                style={{ ...(selectedFunctionId === fn.id ? primaryButtonStyle : buttonStyle), flex: 1, textAlign: 'left' }}
                onClick={() => {
                  setSelectedFunctionId(fn.id)
                  setFunctionForm({ ...fn })
                  setFunctionAssignmentForm(null)
                }}
              >
                {fn.name}
              </button>
              <button style={buttonStyle} onClick={() => moveFunction(fn.id, 'up')}>↑</button>
              <button style={buttonStyle} onClick={() => moveFunction(fn.id, 'down')}>↓</button>
              <button style={buttonStyle} onClick={() => createNewFunction(selectedAreaId, fn.id)}>+ Sub</button>
            </div>
            <div style={{ marginTop: 6 }}>{renderFunctionTreeForArea(fn.id, depth + 1)}</div>
          </div>
        ))}
      </div>
    )
  }

