function findProject(workItem, workItemMap) {
  let current = workItem
  const visited = new Set()

  while (current) {
    if (visited.has(current.id)) return null
    visited.add(current.id)

    if (current.type === 'project') return current
    if (!current.parent_work_item_id) return null

    current = workItemMap.get(current.parent_work_item_id)
  }

  return null
}

async function swapSortOrder(table, first, second) {
  const a = first.sort_order ?? 0
  const b = second.sort_order ?? 0

  const res1 = await supabase.from(table).update({ sort_order: b }).eq('id', first.id)
  if (res1.error) throw res1.error

  const res2 = await supabase.from(table).update({ sort_order: a }).eq('id', second.id)
  if (res2.error) throw res2.error
}

function EditorApp() {
