          {sortedAreas.map((area) => {
            const isOpen = openFunctionAreaIds.includes(area.id)
            return (
              <div key={area.id} style={boxStyle}>
                <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
                  <button
                    onClick={() =>
                      setOpenFunctionAreaIds((prev) =>
                        prev.includes(area.id) ? prev.filter((id) => id !== area.id) : [...prev, area.id]
                      )
                    }
                    style={{ ...buttonStyle, flex: 1, textAlign: 'left' }}
                  >
                    {isOpen ? '−' : '+'} {area.name}
                  </button>
                </div>

                {isOpen ? renderFunctionsTree(area.id) : null}
              </div>
            )
          })}
