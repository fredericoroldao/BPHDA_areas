        <div style={boxStyle}>
          <div style={{ fontSize: 12, color: '#5f6f66' }}>
            Esta vista mantém-se temporariamente como apoio técnico. A edição principal de funções e subfunções está agora dentro de Áreas.
          </div>
        </div>
      </div>
    )
  }

