                      <label>Tipo de dependência<select style={inputStyle} value={dependencyForm.dependency_type} onChange={(e) => setDependencyForm((s) => ({ ...s, dependency_type: e.target.value }))}>{dependencyTypeOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
                      <label>Lag em dias<input type="number" style={inputStyle} value={dependencyForm.lag_days ?? 0} onChange={(e) => setDependencyForm((s) => ({ ...s, lag_days: e.target.value }))} /></label>

                      <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
                        <button style={primaryButtonStyle} onClick={saveDependency}>Gravar dependência</button>
                        <button style={buttonStyle} onClick={() => setDependencyForm(null)}>Cancelar</button>
                        {dependencyForm.id ? <button style={dangerButtonStyle} onClick={() => removeRow('work_item_dependencies', dependencyForm.id)}>Apagar</button> : null}
                      </div>
                    </div>
                  ) : null}
                </div>
              ) : null}
            </div>
          ) : (
            <div>Escolhe um projeto, tarefa ou cria um novo.</div>
          )}
        </div>
      </div>
    )
  }

  function renderDependenciesTab() {
    return (
      <div style={{ display: 'grid', gridTemplateColumns: '420px 1fr', gap: 16, alignItems: 'start' }}>
        <div style={boxStyle}>
          <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
            <strong>Dependências</strong>
            <button onClick={createNewDependency} style={primaryButtonStyle}>+ Criar</button>
          </div>

          <div style={{ display: 'grid', gap: 10 }}>
            <label>Projeto da tarefa origem<select style={inputStyle} value={dependencySourceProjectId} onChange={(e) => setDependencySourceProjectId(e.target.value)}><option value="">Escolher</option>{projects.map((project) => <option key={project.id} value={project.id}>{project.name}</option>)}</select></label>
            <label>Projeto da tarefa destino<select style={inputStyle} value={dependencyTargetProjectId} onChange={(e) => setDependencyTargetProjectId(e.target.value)}><option value="">Escolher</option>{projects.map((project) => <option key={project.id} value={project.id}>{project.name}</option>)}</select></label>
          </div>

          <div style={{ marginTop: 12, display: 'grid', gap: 6 }}>
            {dependencies.map((dep) => {
              const pred = workItemMap.get(dep.predecessor_work_item_id)
              const succ = workItemMap.get(dep.successor_work_item_id)
              return (
                <button
                  key={dep.id}
                  style={{ ...(selectedDependencyId === dep.id ? primaryButtonStyle : buttonStyle), textAlign: 'left' }}
                  onClick={() => {
                    setSelectedDependencyId(dep.id)
                    setDependencyForm({ ...dep })
                    const predProject = pred ? findProject(pred, workItemMap)?.id ?? '' : ''
                    const succProject = succ ? findProject(succ, workItemMap)?.id ?? '' : ''
                    setDependencySourceProjectId(predProject)
                    setDependencyTargetProjectId(succProject)
                  }}
                >
                  {(pred?.name ?? 'Sem origem')} → {(succ?.name ?? 'Sem destino')}
                </button>
              )
            })}
          </div>
        </div>

        <div style={boxStyle}>
          {dependencyForm ? (
            <div style={{ display: 'grid', gap: 10 }}>
              <label>Tarefa origem<select style={inputStyle} value={dependencyForm.predecessor_work_item_id} onChange={(e) => setDependencyForm((s) => ({ ...s, predecessor_work_item_id: e.target.value }))}><option value="">Escolher</option>{filteredDependencySourceItems.map((item) => <option key={item.id} value={item.id}>{workItemLabel(item)}</option>)}</select></label>
              <label>Tarefa destino<select style={inputStyle} value={dependencyForm.successor_work_item_id} onChange={(e) => setDependencyForm((s) => ({ ...s, successor_work_item_id: e.target.value }))}><option value="">Escolher</option>{filteredDependencyTargetItems.map((item) => <option key={item.id} value={item.id}>{workItemLabel(item)}</option>)}</select></label>
              <label>Tipo de dependência<select style={inputStyle} value={dependencyForm.dependency_type} onChange={(e) => setDependencyForm((s) => ({ ...s, dependency_type: e.target.value }))}>{dependencyTypeOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
              <label>Lag em dias<input type="number" style={inputStyle} value={dependencyForm.lag_days ?? 0} onChange={(e) => setDependencyForm((s) => ({ ...s, lag_days: e.target.value }))} /></label>

              <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
                <button style={primaryButtonStyle} onClick={saveDependency}>Gravar</button>
                <button style={buttonStyle} onClick={() => setDependencyForm(null)}>Cancelar</button>
                {dependencyForm.id ? <button style={dangerButtonStyle} onClick={() => removeRow('work_item_dependencies', dependencyForm.id)}>Apagar</button> : null}
              </div>
            </div>
          ) : (
            <div>Escolhe uma dependência ou cria uma nova.</div>
          )}
        </div>
      </div>
    )
  }

  function renderAssignmentsTab() {
    return (
      <div style={boxStyle}>
        <div style={{ fontSize: 12, color: '#5f6f66' }}>
          As atribuições principais de áreas e funções estão agora integradas em Áreas. Esta secção mantém-se apenas para atribuições de projetos e tarefas.
        </div>

        <div style={{ display: 'grid', gridTemplateColumns: '360px 1fr', gap: 16, alignItems: 'start', marginTop: 16 }}>
          <div style={boxStyle}>
            <div style={{ display: 'flex', justifyContent: 'space-between', gap: 8, marginBottom: 10 }}>
              <strong>Atribuições de projeto / tarefa</strong>
              <button onClick={createNewWorkItemAssignment} style={primaryButtonStyle}>+ Criar</button>
            </div>
            <div style={{ display: 'grid', gap: 6 }}>
              {workItemPeople.map((row) => {
                const item = workItems.find((x) => x.id === row.work_item_id)
                return (
                  <button
                    key={row.id}
                    style={{ ...(selectedWorkItemAssignmentId === row.id ? primaryButtonStyle : buttonStyle), textAlign: 'left' }}
                    onClick={() => {
                      setSelectedWorkItemAssignmentId(row.id)
                      setWorkItemAssignmentForm({ ...row })
                    }}
                  >
                    {item ? workItemLabel(item) : 'Projeto / tarefa'} → {personName(row.person_id)}
                  </button>
                )
              })}
            </div>
          </div>

          <div style={boxStyle}>
            {workItemAssignmentForm ? (
              <div style={{ display: 'grid', gap: 10 }}>
                <label>Projeto / tarefa<select style={inputStyle} value={workItemAssignmentForm.work_item_id} onChange={(e) => setWorkItemAssignmentForm((s) => ({ ...s, work_item_id: e.target.value }))}>{sortedWorkItems.map((item) => <option key={item.id} value={item.id}>{workItemLabel(item)}</option>)}</select></label>
                <label>Pessoa<select style={inputStyle} value={workItemAssignmentForm.person_id} onChange={(e) => setWorkItemAssignmentForm((s) => ({ ...s, person_id: e.target.value }))}>{people.map((person) => <option key={person.id} value={person.id}>{person.name}</option>)}</select></label>
                <label>Papel<select style={inputStyle} value={workItemAssignmentForm.assignment_role} onChange={(e) => setWorkItemAssignmentForm((s) => ({ ...s, assignment_role: e.target.value }))}>{genericRoleOptions.map(([value, label]) => <option key={value} value={value}>{label}</option>)}</select></label>
                <label style={{ display: 'flex', gap: 8, alignItems: 'center' }}><input type="checkbox" checked={!!workItemAssignmentForm.is_primary} onChange={(e) => setWorkItemAssignmentForm((s) => ({ ...s, is_primary: e.target.checked }))} />Principal</label>

                <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
                  <button style={primaryButtonStyle} onClick={saveWorkItemAssignment}>Gravar</button>
                  <button style={buttonStyle} onClick={() => setWorkItemAssignmentForm(null)}>Cancelar</button>
                  {workItemAssignmentForm.id ? <button style={dangerButtonStyle} onClick={() => removeRow('work_item_people', workItemAssignmentForm.id)}>Apagar</button> : null}
                </div>
              </div>
            ) : (
              <div>Escolhe uma atribuição de projeto / tarefa ou cria uma nova.</div>
            )}
          </div>
        </div>
      </div>
    )
  }

  return (
    <>
      <style>{`
        :root {
          font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          color: #1d2a21;
          background: #f6f8f4;
        }

        html, body, #root {
          margin: 0;
          min-height: 100%;
          width: 100%;
        }

        body {
          background: #f6f8f4;
          color: #1d2a21;
        }

        * {
          box-sizing: border-box;
        }

        label {
          display: grid;
          gap: 4px;
          font-size: 12px;
          color: #46604d;
        }

        select, input, textarea, button {
          font: inherit;
        }

        textarea {
          resize: vertical;
        }
      `}</style>

      <div style={{ maxWidth: 1700, margin: '0 auto', padding: '24px 18px 40px' }}>
        <header style={{ marginBottom: 18 }}>
          <img
            src="https://img.brainstormphda.pt/marca/logo/BPHDA_logo_pt_horizontal_verde.svg"
            alt="BPHDA"
            style={{ display: 'block', height: 34, width: 'auto', marginBottom: 14 }}
          />
          <h1 style={{ margin: 0, fontSize: 26, lineHeight: 1.05, color: '#16361f' }}>
            Editor de dados
          </h1>
          <div style={{ marginTop: 8, display: 'flex', gap: 8, flexWrap: 'wrap' }}>
            <a href="/" style={{ ...buttonStyle, textDecoration: 'none', display: 'inline-block' }}>
              Voltar à vista principal
            </a>
            <button onClick={loadAll} style={buttonStyle}>
              Recarregar dados
            </button>
          </div>
        </header>

        <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap', marginBottom: 16 }}>
          {[
            ['people', 'Pessoas'],
            ['areas', 'Áreas'],
            ['functions', 'Funções'],
            ['work_items', 'Projetos e tarefas'],

            ['assignments', 'Atribuições'],
          ].map(([key, label]) => (
            <button key={key} onClick={() => setTab(key)} style={tab === key ? primaryButtonStyle : buttonStyle}>
              {label}
            </button>
          ))}
        </div>

        {loading ? (
          <div style={boxStyle}>A carregar...</div>
        ) : (
          <>
            {error ? (
              <div style={{ ...boxStyle, background: '#fff4f4', borderColor: '#efcaca', color: '#8a2f2f', marginBottom: 12 }}>
                {error}
              </div>
            ) : null}

            {message ? (
              <div style={{ ...boxStyle, background: '#eef6e8', borderColor: '#cfe0c4', color: '#35513c', marginBottom: 12 }}>
                {message}
              </div>
            ) : null}

            {tab === 'people' ? renderPeopleTab() : null}
            {tab === 'areas' ? renderAreasTab() : null}
            {tab === 'functions' ? renderFunctionsTab() : null}
            {tab === 'work_items' ? renderWorkItemsTab() : null}

            {tab === 'assignments' ? renderAssignmentsTab() : null}
          </>
        )}
      </div>
    </>
  )
}

createRoot(document.getElementById('root')).render(<EditorApp />)
