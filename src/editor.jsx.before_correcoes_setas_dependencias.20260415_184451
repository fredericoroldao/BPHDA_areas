  async function moveArea(id, direction) {
    const index = sortedAreas.findIndex((item) => item.id === id)
    const target = direction === 'up' ? index - 1 : index + 1
    if (index === -1 || target < 0 || target >= sortedAreas.length) return

    try {
      setSaving(true)
      clearMessages()
      await swapSortOrder('areas', sortedAreas[index], sortedAreas[target])
      setMessage('Ordem das áreas atualizada.')
      await loadAll()
    } catch (err) {
      setError(err.message)
    } finally {
      setSaving(false)
    }
  }

  async function moveFunction(id, direction) {
    const current = functions.find((fn) => fn.id === id)
    if (!current) return

    const siblings = sortedFunctions.filter(
      (fn) =>
        fn.area_id === current.area_id &&
        (fn.parent_function_id ?? '') === (current.parent_function_id ?? '')
    )
    const index = siblings.findIndex((item) => item.id === id)
    const target = direction === 'up' ? index - 1 : index + 1
    if (index === -1 || target < 0 || target >= siblings.length) return

    try {
      setSaving(true)
      clearMessages()
      await swapSortOrder('functions', siblings[index], siblings[target])
      setMessage('Ordem das funções atualizada.')
      await loadAll()
    } catch (err) {
      setError(err.message)
    } finally {
      setSaving(false)
    }
  }

  async function moveWorkItem(id, direction) {
    const current = workItems.find((item) => item.id === id)
    if (!current) return

    const siblings = sortedWorkItems.filter(
      (item) => (item.parent_work_item_id ?? '') === (current.parent_work_item_id ?? '')
    )
    const index = siblings.findIndex((item) => item.id === id)
    const target = direction === 'up' ? index - 1 : index + 1
    if (index === -1 || target < 0 || target >= siblings.length) return

    try {
      setSaving(true)
      clearMessages()
      await swapSortOrder('work_items', siblings[index], siblings[target])
      setMessage('Ordem das tarefas atualizada.')
      await loadAll()
    } catch (err) {
      setError(err.message)
    } finally {
      setSaving(false)
    }
  }

  async function savePerson() {
    if (!personForm?.name?.trim()) {
      setError('O nome é obrigatório.')
      return
    }

    const ok = await saveManual(
      'people',
      personForm,
      {
        name: personForm.name,
        email: personForm.email || null,
        role_title: personForm.role_title || null,
        status: personForm.status,
      },
      'Pessoa gravada com sucesso.'
    )

    if (ok && !personForm.id) setPersonForm(null)
  }

  async function saveArea() {
    if (!areaForm?.name?.trim()) {
      setError('O nome da área é obrigatório.')
      return
    }

    const payload = {
      name: areaForm.name,
      description: areaForm.description || null,
      notes: areaForm.notes || null,
      status: areaForm.status,
    }

    if (!areaForm.id) {
      payload.sort_order = (sortedAreas.at(-1)?.sort_order ?? 0) + 1
    } else {
      payload.sort_order = areaForm.sort_order ?? 0
    }

    const ok = await saveManual('areas', areaForm, payload, 'Área gravada com sucesso.')
    if (ok && !areaForm.id) setAreaForm(null)
  }

  async function saveFunction() {
    if (!functionForm?.area_id) {
      setError('Escolhe uma área.')
      return
    }
    if (!functionForm?.name?.trim()) {
      setError('O nome da função é obrigatório.')
      return
    }

    const siblings = sortedFunctions.filter(
      (fn) =>
        fn.area_id === functionForm.area_id &&
        (fn.parent_function_id ?? '') === (functionForm.parent_function_id ?? '') &&
        fn.id !== functionForm.id
    )

    const payload = {
      area_id: functionForm.area_id,
      parent_function_id: functionForm.parent_function_id || null,
      name: functionForm.name,
      description: functionForm.description || null,
      notes: functionForm.notes || null,
      status: functionForm.status,
      level: functionForm.parent_function_id ? 2 : 1,
    }

    if (!functionForm.id) {
      payload.sort_order = siblings.length ? Math.max(...siblings.map((x) => x.sort_order ?? 0)) + 1 : 1
    } else {
      payload.sort_order = functionForm.sort_order ?? 0
    }

    const ok = await saveManual('functions', functionForm, payload, 'Função gravada com sucesso.')
    if (ok && !functionForm.id) setFunctionForm(null)
  }

  async function saveWorkItem() {
    if (!workItemForm?.name?.trim()) {
      setError('O nome é obrigatório.')
      return
    }

    const siblings = sortedWorkItems.filter(
      (item) =>
        (item.parent_work_item_id ?? '') === (workItemForm.parent_work_item_id ?? '') &&
        item.id !== workItemForm.id
    )

    const payload = {
      parent_work_item_id: workItemForm.parent_work_item_id || null,
      type: workItemForm.type,
      name: workItemForm.name,
      description: workItemForm.description || null,
      status: workItemForm.status,
      phase: workItemForm.phase,
      priority: workItemForm.priority,
    }

    if (!workItemForm.id) {
      payload.sort_order = siblings.length ? Math.max(...siblings.map((x) => x.sort_order ?? 0)) + 1 : 1
    } else {
      payload.sort_order = workItemForm.sort_order ?? 0
    }

    const ok = await saveManual('work_items', workItemForm, payload, 'Projeto / tarefa gravado com sucesso.')
    if (ok && !workItemForm.id) setWorkItemForm(null)
  }

  async function saveDependency() {
    if (!dependencyForm?.predecessor_work_item_id || !dependencyForm?.successor_work_item_id) {
      setError('Escolhe tarefa origem e tarefa destino.')
      return
